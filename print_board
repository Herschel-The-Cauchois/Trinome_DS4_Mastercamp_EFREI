import math

ROWS = 6
COLS = 12
AI = 1
OPPONENT = -1
EMPTY = 0

MAX_DEPTH = 4
TIME_LIMIT = 9.5


def print_board(board):

    symbols = {
        AI: "X",
        OPPONENT: "O",
        EMPTY: "."
    }

    print()
    for row in board:
        print(" ".join(symbols[cell] for cell in row))

    print(" ".join(str(i % 10) for i in range(COLS)))
    print()
